---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Jing Betty Feng | Professor, Researcher, and Academic Leader"
  description="Official website of Jing Betty Feng, Professor and SUNY AI for Public Good Fellow working at the intersection of global business, AI, innovation, and workforce learning."
>

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="home-hero" aria-label="Introduction">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <p class="hero-label">Professor &amp; Scholar-Practitioner</p>
          <h1 class="hero-name">Jing Betty Feng</h1>
          <p class="hero-subtitle">
            Professor of International Business &nbsp;·&nbsp; AI, <br />
            Innovation, and Workforce Learning
          </p>
          <p class="hero-body">
            A professor, academic leader, and SUNY AI for Public Good Fellow whose
            teaching, research, and public-facing work are grounded in prior
            experience at multinational firms — bringing organizational insight
            into the classroom, scholarship, and community partnerships.
          </p>
          <div class="btn-group hero-cta">
            <a href="/about" class="btn btn--primary">About Betty</a>
            <a href="/research" class="btn btn--outline-light">Explore Research</a>
          </div>
        </div>
        <div class="hero-portrait">
          <img
            src="/feng.png"
            alt="Jing Betty Feng, Professor of Business at SUNY Farmingdale State College"
            width="640"
            height="800"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CREDIBILITY STRIP
  ══════════════════════════════════════════════ -->
  <section class="honors-band" aria-label="Affiliations and honors">
    <div class="container">
      <ul class="honors-band__list">
        <li class="honors-band__item">
          <strong>SUNY AI for Public Good Fellow</strong>
          AI Initiative
        </li>
        <li class="honors-band__item">
          <strong>Academy of International Business</strong>
          Member &amp; Service Leader
        </li>
        <li class="honors-band__item">
          <strong>AACSB Accreditation</strong>
          Assessment Leadership
        </li>
        <li class="honors-band__item">
          <strong>Grant-Funded Scholarship</strong>
          Multiple Funded Initiatives
        </li>
        <li class="honors-band__item">
          <strong>Innovation Challenge</strong>
          Faculty Lead
        </li>
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       AREAS OF WORK
  ══════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="areas-heading">
    <div class="container">
      <div class="section-header--center">
        <p class="section-label">Teaching, Research &amp; Engagement</p>
        <h2 class="section-title" id="areas-heading">Areas of Focus</h2>
        <p class="section-intro text-center" style="margin-inline:auto;">
          Betty's work spans four interconnected domains — each informed by
          global industry experience and a commitment to applied, human-centered learning.
        </p>
      </div>
      <div class="grid-4">
        <div class="card">
          <div class="card-icon">🤖</div>
          <div class="card-label">Emerging Technologies</div>
          <h3 class="card-title">AI and Business Education</h3>
          <p class="card-body">
            Integrating AI literacy, responsible technology adoption, and
            human-centered design into business curricula and organizational learning.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">🌐</div>
          <div class="card-label">International Perspective</div>
          <h3 class="card-title">Global Business and Cross-Cultural Learning</h3>
          <p class="card-body">
            Examining international management, cultural dynamics, and the
            organizational challenges of operating across national contexts.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">💡</div>
          <div class="card-label">Applied Learning</div>
          <h3 class="card-title">Innovation and Experiential Education</h3>
          <p class="card-body">
            Designing learning experiences that connect theory to practice through
            entrepreneurship, competition, and project-based engagement.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">🌱</div>
          <div class="card-label">Community Impact</div>
          <h3 class="card-title">Sustainability and Workforce Development</h3>
          <p class="card-body">
            Partnering with regional organizations on workforce learning,
            sustainability initiatives, and inclusive economic development.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       PHILOSOPHY BLOCK
  ══════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="philosophy-heading">
    <div class="container">
      <div class="philosophy-layout">
        <div class="philosophy-header">
          <p class="section-label">Academic Philosophy</p>
          <h2 id="philosophy-heading">Scholarship Grounded in Practice</h2>
          <div class="section-divider"></div>
          <p>
            Before entering academia, Betty worked in global firms across multiple
            industries and geographies. That experience didn't stay in the past —
            it shapes every course she teaches, every research question she pursues,
            and every partnership she builds.
          </p>
          <a href="/about" class="btn btn--outline" style="margin-top:var(--space-6);">
            Read the Full Story
          </a>
        </div>
        <div class="philosophy-block">
          <p class="philosophy-block__text">
            "The most effective educators bring the complexity of the real world into
            the classroom — not to simplify it, but to help students develop the
            frameworks to navigate it. My years in multinational firms gave me that
            complexity firsthand. Academic scholarship gives me the tools to
            make it legible."
          </p>
          <p class="philosophy-block__attribution">— Jing Betty Feng</p>
          <div style="height:1.5rem;"></div>
          <p class="philosophy-block__body">
            This scholar-practitioner identity — professional experience interpreted
            through rigorous scholarship — defines Betty's approach to teaching,
            mentorship, curriculum design, and interdisciplinary research.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       TEACHING SNAPSHOT
  ══════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="teaching-heading">
    <div class="container">
      <div class="snapshot-header">
        <div>
          <p class="section-label">In the Classroom</p>
          <h2 id="teaching-heading">Teaching Snapshot</h2>
          <p class="section-intro">
            Betty teaches at both undergraduate and graduate levels, designing
            courses that link disciplinary theory to organizational reality.
          </p>
        </div>
        <a href="/teaching" class="btn btn--outline snapshot-cta">Explore Teaching</a>
      </div>

      <div class="grid-3" style="margin-top:var(--space-10);">
        <div class="card card--flat">
          <div class="card-label">Course Portfolio</div>
          <h3 class="card-title">Courses Taught</h3>
          <ul class="snapshot-list">
            <li>International Business Strategy</li>
            <li>Cross-Cultural Management</li>
            <li>AI and Business Innovation</li>
            <li>Negotiation &amp; Decision Making</li>
            <li>Entrepreneurship &amp; Venture Design</li>
            <li>Sustainability in Global Business</li>
          </ul>
        </div>
        <div class="card card--flat">
          <div class="card-label">Design Work</div>
          <h3 class="card-title">Curriculum Development</h3>
          <ul class="snapshot-list">
            <li>AI literacy modules for business students</li>
            <li>Workforce development non-credit programs</li>
            <li>Interdisciplinary sustainability curriculum</li>
            <li>Experiential entrepreneurship courses</li>
          </ul>
        </div>
        <div class="card card--flat">
          <div class="card-label">Pedagogical Approach</div>
          <h3 class="card-title">Teaching Philosophy</h3>
          <ul class="snapshot-list">
            <li>Theory connected to organizational reality</li>
            <li>Global and cross-cultural awareness</li>
            <li>Problem-solving through active learning</li>
            <li>Ethical reflection on emerging technology</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       LEADERSHIP & IMPACT SNAPSHOT
  ══════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="leadership-heading">
    <div class="container">
      <div class="snapshot-header">
        <div>
          <p class="section-label">Beyond the Classroom</p>
          <h2 id="leadership-heading">Leadership &amp; Impact</h2>
          <p class="section-intro">
            Betty's leadership extends from curriculum and program development
            to grant-funded initiatives and regional community engagement.
          </p>
        </div>
        <a href="/leadership" class="btn btn--outline snapshot-cta">View Leadership</a>
      </div>

      <div class="grid-4" style="margin-top:var(--space-10);">
        <div class="impact-card">
          <div class="impact-card__icon">🏛️</div>
          <h3 class="impact-card__title">Academic Leadership</h3>
          <p class="impact-card__body">
            Committee and program leadership, faculty development, and
            disciplinary service through AIB and other associations.
          </p>
        </div>
        <div class="impact-card">
          <div class="impact-card__icon">📋</div>
          <h3 class="impact-card__title">Grants &amp; Funded Work</h3>
          <p class="impact-card__body">
            Multiple funded initiatives spanning AI education, workforce
            development, and sustainability research partnerships.
          </p>
        </div>
        <div class="impact-card">
          <div class="impact-card__icon">✅</div>
          <h3 class="impact-card__title">AACSB &amp; Assessment</h3>
          <p class="impact-card__body">
            Supporting accreditation-aligned assurance of learning, societal
            impact reporting, and institutional quality improvement.
          </p>
        </div>
        <div class="impact-card">
          <div class="impact-card__icon">🤝</div>
          <h3 class="impact-card__title">Community Engagement</h3>
          <p class="impact-card__body">
            Regional partnerships in Long Island, offshore wind workforce
            development, MWBE initiatives, and sustainability programs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       RESEARCH THEMES SNAPSHOT
  ══════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="research-heading">
    <div class="container">
      <div class="snapshot-header">
        <div>
          <p class="section-label">Scholarship</p>
          <h2 id="research-heading">Research Themes</h2>
          <p class="section-intro">
            Betty's scholarship is organized around three intersecting themes
            that connect organizational theory, global context, and applied learning.
          </p>
        </div>
        <a href="/research" class="btn btn--outline snapshot-cta">View Research</a>
      </div>

      <div class="grid-3" style="margin-top:var(--space-10);">
        <div class="research-theme">
          <div class="research-theme__number">01</div>
          <h3 class="research-theme__title">AI, Learning, and Organizational Behavior</h3>
          <p class="research-theme__body">
            How organizations and individuals adapt to AI — examining learning
             processes, behavioral responses, and managerial implications of 
            AI adoption across industries.
          </p>
        </div>
        <div class="research-theme">
          <div class="research-theme__number">02</div>
          <h3 class="research-theme__title">Global Identity, Culture, and International Business</h3>
          <p class="research-theme__body">
            Cross-cultural dynamics in multinational contexts, global organizational 
            identity, sustainablity of MNEs, and the human dimensions of global business strategy.
          </p>
        </div>
        <div class="research-theme">
          <div class="research-theme__number">03</div>
          <h3 class="research-theme__title">Innovation, Pedagogy, and Experiential Learning</h3>
          <p class="research-theme__body">
            How innovative teaching methods — from design thinking to
            entrepreneurship challenges — develop practical capabilities and
            disciplinary understanding in business students.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       HONORS BAND
  ══════════════════════════════════════════════ -->
  <section class="honors-section" aria-label="Selected honors and recognitions">
    <div class="container">
      <p class="section-label text-center" style="margin-bottom:var(--space-6);">
        Selected Honors, Fellowships &amp; Recognition
      </p>
      <div class="honors-row">
        <div class="honor-chip">
          <span class="honor-chip__title">SUNY AI for Public Good Fellow</span>
        </div>
        <div class="honor-chip">
          <span class="honor-chip__title">Innovation Challenge Faculty Lead</span>
        </div>
        <div class="honor-chip">
          <span class="honor-chip__title">Grant-Funded Workforce Research</span>
        </div>
        <div class="honor-chip">
          <span class="honor-chip__title">AIB Member &amp; Service Leader</span>
        </div>
        <div class="honor-chip">
          <span class="honor-chip__title">AACSB Assessment Leader</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       SPEAKING CTA
  ══════════════════════════════════════════════ -->
  <section class="section section--dark" aria-labelledby="speaking-cta-heading">
    <div class="container text-center">
      <p class="section-label section-label--light">Collaboration &amp; Engagement</p>
      <h2 id="speaking-cta-heading" style="color:#fff;margin-bottom:var(--space-4);">
        Open to Speaking, Collaboration,<br />and Cross-Sector Partnership
      </h2>
      <p class="section-intro section-intro--light" style="margin-inline:auto;margin-bottom:var(--space-8);">
        Betty welcomes invitations for talks, workshops, panels, and academically
        aligned partnerships in AI education, global business, innovation, and
        workforce development.
      </p>
      <div class="btn-group" style="justify-content:center;">
        <a href="/speaking" class="btn btn--outline-light">Speaking Topics</a>
        <a href="/contact" class="btn btn--outline-light">Inquire About Collaboration</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────── */
  .home-hero {
    background: var(--color-bg-dark);
    padding-block: var(--space-24) var(--space-20);
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-16);
    align-items: center;
  }
  .hero-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-4);
  }
  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 600;
    color: #fff;
    line-height: 1.1;
    margin-bottom: var(--space-3);
  }
  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2vw, 1.375rem);
    font-weight: 400;
    color: rgba(255,255,255,0.65);
    margin-bottom: var(--space-6);
    line-height: 1.5;
  }
  .hero-body {
    font-size: var(--text-base);
    color: rgba(255,255,255,0.75);
    max-width: 560px;
    line-height: 1.75;
    margin-bottom: var(--space-8);
  }

  .hero-portrait img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 860px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-portrait { display: none; }
  }

  /* ── Philosophy ───────────────────────────────── */
  .philosophy-layout {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: var(--space-16);
    align-items: start;
  }
  .philosophy-header h2 { margin-bottom: var(--space-4); }
  .philosophy-header p { color: var(--color-text-muted); line-height: 1.75; }
  .philosophy-header .section-divider { margin-bottom: var(--space-6); }
  @media (max-width: 800px) {
    .philosophy-layout { grid-template-columns: 1fr; }
  }

  /* ── Snapshot shared ──────────────────────────── */
  .snapshot-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }
  .snapshot-header h2 { margin-bottom: var(--space-3); }
  .snapshot-header .section-intro { margin-bottom: 0; }
  .snapshot-cta { flex-shrink: 0; align-self: center; }

  .snapshot-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .snapshot-list li {
    padding: var(--space-2) 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border-light);
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .snapshot-list li::before { content: '–'; color: var(--color-gold); flex-shrink: 0; }
  .snapshot-list li:last-child { border-bottom: none; }

  /* ── Impact cards ─────────────────────────────── */
  .impact-card {
    padding: var(--space-8);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
  }
  .impact-card__icon { font-size: 2rem; margin-bottom: var(--space-4); }
  .impact-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-3);
    color: var(--color-accent);
  }
  .impact-card__body {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Research themes ──────────────────────────── */
  .research-theme {
    padding: var(--space-8);
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
  }
  .research-theme__number {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-accent-light);
    line-height: 1;
    margin-bottom: var(--space-3);
  }
  .research-theme__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-3);
    color: var(--color-text);
  }
  .research-theme__body {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* ── Honors ───────────────────────────────────── */
  .honors-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
    padding-block: var(--space-10);
  }
  .honors-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }
  .honor-chip {
    background: var(--color-accent-light);
    border: 1px solid rgba(29,53,87,0.12);
    border-radius: 100px;
    padding: 0.4rem 1.25rem;
  }
  .honor-chip__title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }
</style>
