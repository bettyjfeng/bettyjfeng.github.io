---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact | Jing Betty Feng"
  description="Contact Jing Betty Feng for speaking invitations, academic collaboration, grant partnerships, and professionally aligned opportunities."
>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__label">Contact</p>
      <h1 class="page-hero__title">Get in Touch</h1>
      <p class="page-hero__intro">
        Betty welcomes inquiries related to speaking, academic collaboration,
        grants, workshops, curriculum development, and professionally aligned partnerships.
      </p>
    </div>
  </section>

  <!-- CONTACT MAIN -->
  <section class="section" aria-labelledby="contact-heading">
    <div class="container">
      <div class="contact-layout">

        <!-- FORM -->
        <div class="contact-main-col">
          <p class="section-label">Send a Message</p>
          <h2 id="contact-heading">Inquiry Form</h2>
          <div class="section-divider"></div>

          <p class="contact-intro">
            Please include your organization, the nature of the invitation
            or collaboration, and any relevant timeline.
            Betty reviews all professional inquiries personally.
          </p>

          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="contact-form"
            novalidate
          >
            <!-- Web3Forms access key -->
            <input type="hidden" name="access_key" value="fc77e4fe-0216-4821-9dde-96ac32719d51" />
            <!-- Custom subject line in the email Betty receives -->
            <input type="hidden" name="subject" value="New inquiry via bettyfeng.us" />
            <!-- Redirect to same page after submission (handled by JS below instead) -->
            <input type="hidden" name="redirect" value="false" />

            <div class="form-row">
              <div class="form-group">
                <label for="first-name" class="form-label">First Name <span aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="first-name"
                  name="first_name"
                  class="form-input"
                  required
                  autocomplete="given-name"
                  placeholder="Jane"
                />
              </div>
              <div class="form-group">
                <label for="last-name" class="form-label">Last Name <span aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="last-name"
                  name="last_name"
                  class="form-input"
                  required
                  autocomplete="family-name"
                  placeholder="Smith"
                />
              </div>
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email Address <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                required
                autocomplete="email"
                placeholder="you@organization.edu"
              />
            </div>

            <div class="form-group">
              <label for="organization" class="form-label">Organization</label>
              <input
                type="text"
                id="organization"
                name="organization"
                class="form-input"
                autocomplete="organization"
                placeholder="University or organization name"
              />
            </div>

            <div class="form-group">
              <label for="inquiry-type" class="form-label">Nature of Inquiry <span aria-hidden="true">*</span></label>
              <select id="inquiry-type" name="inquiry_type" class="form-select" required>
                <option value="" disabled selected>Select one…</option>
                <option value="Speaking / Invited Lecture">Speaking / Invited Lecture</option>
                <option value="Workshop or Facilitation">Workshop or Facilitation</option>
                <option value="Academic Collaboration">Academic Collaboration</option>
                <option value="Grant Partnership">Grant Partnership</option>
                <option value="Curriculum Development">Curriculum Development</option>
                <option value="Media / Podcast Inquiry">Media / Podcast Inquiry</option>
                <option value="Student Inquiry">Student Inquiry</option>
                <option value="Other Professional Inquiry">Other Professional Inquiry</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Message <span aria-hidden="true">*</span></label>
              <textarea
                id="message"
                name="message"
                class="form-textarea"
                required
                rows="6"
                placeholder="Please describe the invitation or opportunity, including any relevant timeline…"
              ></textarea>
            </div>

            <!-- Honeypot — catches bots, invisible to real users -->
            <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />

            <button type="submit" id="submit-btn" class="btn btn--primary contact-submit">
              Send Inquiry
            </button>

            <div id="form-success" class="form-success" aria-live="polite" hidden>
              <strong>✓ Message received.</strong> Thank you for reaching out —
              Betty will respond when able.
            </div>
            <div id="form-error" class="form-error" aria-live="polite" hidden>
              <strong>Something went wrong.</strong> Please try again in a moment.
            </div>
          </form>
        </div>

        <!-- SIDEBAR -->
        <aside class="contact-sidebar" aria-label="Contact details">
          <div class="contact-info-card">
            <h3 class="contact-info-card__title">Institution</h3>
            <p class="contact-info-value">
              SUNY Farmingdale State College<br />
              School of Business
            </p>
          </div>

          <div class="contact-info-card">
            <h3 class="contact-info-card__title">Appropriate Inquiries</h3>
            <ul class="inquiry-list">
              <li>Speaking and invited lectures</li>
              <li>Workshop and facilitation requests</li>
              <li>Academic collaboration and co-authorship</li>
              <li>Grant and funded project partnerships</li>
              <li>Curriculum development conversations</li>
              <li>Media and podcast opportunities</li>
              <li>Student mentorship inquiries</li>
            </ul>
          </div>

          <div class="contact-info-card contact-info-card--note">
            <p>
              Betty reviews all professional inquiries personally.
              Please allow reasonable time for a response during
              active teaching and research periods.
            </p>
          </div>
        </aside>

      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
    }

    const data = new FormData(form);

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      const json = await res.json();

      if (res.ok && json.success) {
        form.reset();
        successMsg?.removeAttribute('hidden');
        errorMsg?.setAttribute('hidden', '');
        if (submitBtn) submitBtn.textContent = 'Sent ✓';
      } else {
        throw new Error(json.message || 'Submission failed');
      }
    } catch {
      errorMsg?.removeAttribute('hidden');
      successMsg?.setAttribute('hidden', '');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Inquiry';
      }
    }
  });
</script>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-16);
    align-items: start;
  }
  @media (max-width: 860px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-sidebar { order: -1; }
  }

  .contact-main-col h2 { margin-bottom: var(--space-4); }

  .contact-intro {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: var(--space-8);
  }

  /* Form */
  .contact-form { display: flex; flex-direction: column; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
  @media (max-width: 500px) { .form-row { grid-template-columns: 1fr; } }

  .contact-submit { margin-top: var(--space-4); align-self: flex-start; }
  .contact-submit:disabled { opacity: 0.65; cursor: not-allowed; }

  .form-success {
    margin-top: var(--space-5);
    padding: var(--space-4) var(--space-5);
    background: #EBF5EB;
    border: 1px solid #C3E0C3;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: #2A5C2A;
    line-height: 1.6;
  }
  .form-error {
    margin-top: var(--space-5);
    padding: var(--space-4) var(--space-5);
    background: #FDEAEA;
    border: 1px solid #F0C4C4;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: #7A2020;
    line-height: 1.6;
  }

  /* Sidebar */
  .contact-sidebar { display: flex; flex-direction: column; gap: var(--space-4); }

  .contact-info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }
  .contact-info-card--note { background: var(--color-bg-alt); }
  .contact-info-card--note p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    font-style: italic;
    margin: 0;
  }
  .contact-info-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-light);
  }
  .contact-info-value {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.65;
    margin: 0;
  }

  .inquiry-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .inquiry-list li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }
  .inquiry-list li::before { content: '✓'; color: var(--color-gold); font-weight: 600; flex-shrink: 0; }
</style>
