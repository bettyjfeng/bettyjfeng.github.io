---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact | Jing Betty Feng"
  description="Contact Jing Betty Feng for speaking invitations, academic collaboration, grant partnerships, and professionally aligned opportunities."
>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__label">Contact</p>
      <h1 class="page-hero__title">Get in Touch</h1>
      <p class="page-hero__intro">
        Betty welcomes inquiries related to speaking, academic collaboration,
        grants, workshops, curriculum development, and professionally aligned partnerships.
      </p>
    </div>
  </section>

  <!-- CONTACT MAIN -->
  <section class="section" aria-labelledby="contact-heading">
    <div class="container">
      <div class="contact-layout">

        <!-- EMAIL CONTACT -->
        <div class="contact-main-col">
          <p class="section-label">Direct Contact</p>
          <h2 id="contact-heading">Send Betty an Email</h2>
          <div class="section-divider"></div>

          <p class="contact-intro">
            The best way to reach Betty is by email. Please include your organization,
            the nature of the invitation or collaboration, and any relevant timeline.
            She reviews all professional inquiries personally.
          </p>

          <a href="mailto:bettyjfeng@gmail.com" class="email-cta">
            <span class="email-cta__icon" aria-hidden="true">✉</span>
            <span class="email-cta__address">bettyjfeng@gmail.com</span>
            <span class="email-cta__action">Send Email →</span>
          </a>

          <div class="contact-guidance">
            <h3>What to include in your message</h3>
            <ul>
              <li>Your name and organization</li>
              <li>The nature of the invitation or opportunity</li>
              <li>Relevant timeline or event date</li>
              <li>Any additional context that would be helpful</li>
            </ul>
          </div>
        </div>

        <!-- SIDEBAR -->
        <aside class="contact-sidebar" aria-label="Contact information">
          <div class="contact-info-card">
            <h3 class="contact-info-card__title">Contact Information</h3>
            <div class="contact-info-item">
              <span class="contact-info-item__label">Email</span>
              <a href="mailto:bettyjfeng@gmail.com" class="contact-info-item__value">
                bettyjfeng@gmail.com
              </a>
            </div>
            <div class="contact-info-item">
              <span class="contact-info-item__label">Institution</span>
              <span class="contact-info-item__value">
                SUNY Farmingdale State College<br />
                School of Business
              </span>
            </div>
          </div>

          <div class="contact-info-card">
            <h3 class="contact-info-card__title">Appropriate Inquiries</h3>
            <ul class="inquiry-list">
              <li>Speaking and invited lectures</li>
              <li>Workshop and facilitation requests</li>
              <li>Academic collaboration and co-authorship</li>
              <li>Grant and funded project partnerships</li>
              <li>Curriculum development conversations</li>
              <li>Media and podcast opportunities</li>
              <li>Student mentorship inquiries</li>
            </ul>
          </div>

          <div class="contact-info-card contact-info-card--note">
            <p>
              Betty reviews all professional inquiries personally.
              Please allow a reasonable amount of time for a response
              during active teaching and research periods.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-16);
    align-items: start;
  }
  @media (max-width: 860px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-sidebar { order: -1; }
  }

  .contact-main-col h2 { margin-bottom: var(--space-4); }

  .contact-intro {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: var(--space-8);
  }

  /* Email CTA block */
  .email-cta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-6) var(--space-8);
    background: var(--color-accent);
    border-radius: var(--radius-lg);
    text-decoration: none;
    margin-bottom: var(--space-10);
    transition: background var(--transition), box-shadow var(--transition);
    flex-wrap: wrap;
  }
  .email-cta:hover {
    background: var(--color-accent-hover);
    box-shadow: var(--shadow-md);
    color: #fff;
  }
  .email-cta__icon {
    font-size: 1.5rem;
    color: rgba(255,255,255,0.7);
    flex-shrink: 0;
  }
  .email-cta__address {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    color: #fff;
    flex: 1;
  }
  .email-cta__action {
    font-size: var(--text-sm);
    font-weight: 500;
    color: rgba(255,255,255,0.65);
    flex-shrink: 0;
  }

  /* Guidance box */
  .contact-guidance {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-8);
  }
  .contact-guidance h3 {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-4);
  }
  .contact-guidance ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .contact-guidance li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }
  .contact-guidance li::before { content: '–'; color: var(--color-gold); flex-shrink: 0; }

  /* Sidebar */
  .contact-sidebar { display: flex; flex-direction: column; gap: var(--space-4); }
  .contact-info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }
  .contact-info-card--note { background: var(--color-bg-alt); }
  .contact-info-card--note p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    font-style: italic;
    margin: 0;
  }
  .contact-info-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-light);
  }
  .contact-info-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-5);
  }
  .contact-info-item:last-child { margin-bottom: 0; }
  .contact-info-item__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }
  .contact-info-item__value {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }
  a.contact-info-item__value {
    color: var(--color-accent);
    text-decoration: none;
  }
  a.contact-info-item__value:hover { text-decoration: underline; }

  .inquiry-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .inquiry-list li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }
  .inquiry-list li::before { content: '✓'; color: var(--color-gold); font-weight: 600; flex-shrink: 0; }
</style>
