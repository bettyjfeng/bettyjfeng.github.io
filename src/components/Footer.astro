---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/teaching', label: 'Teaching' },
  { href: '/research', label: 'Research' },
  { href: '/leadership', label: 'Leadership & Grants' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/cv', label: 'CV' },
  { href: '/contact', label: 'Contact' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">Jing Betty Feng</a>
        <p class="footer-descriptor">
          Professor &amp; Academic Leader<br />
          AI · Global Business · Innovation · Workforce Learning
        </p>
      </div>

      <nav aria-label="Footer navigation">
        <ul class="footer-nav" role="list">
          {navLinks.map(link => (
            <li><a href={link.href} class="footer-nav-link">{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {year} Jing Betty Feng. All rights reserved.
      </p>
      <a href="/contact" class="footer-contact-link">Get in Touch</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-dark);
    color: rgba(255,255,255,0.65);
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-16);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    margin-bottom: var(--space-8);
    align-items: start;
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    display: block;
    margin-bottom: var(--space-3);
    transition: color var(--transition);
  }
  .footer-logo:hover { color: rgba(255,255,255,0.8); }

  .footer-descriptor {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: rgba(255,255,255,0.5);
    margin: 0;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2) var(--space-8);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-nav-link {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color var(--transition);
  }
  .footer-nav-link:hover { color: #fff; }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .footer-copy {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.35);
    margin: 0;
  }
  .footer-contact-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color var(--transition);
  }
  .footer-contact-link:hover { color: #fff; }

  @media (max-width: 700px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
